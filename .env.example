# Database
DATABASE_URL="postgresql://user:password@localhost:5432/resume_agent"

# LLM Providers (set at least one)
# Primary: Anthropic Claude
ANTHROPIC_API_KEY="your_anthropic_key_here"

# Fallback: Cohere (free tier available)
COHERE_API_KEY="your_cohere_key_here"

# Optional: OpenAI (if you want to use it instead)
# OPENAI_API_KEY="your_openai_key_here"

# GitHub (optional, for skill extraction)
GITHUB_TOKEN="your_github_token"

# Email finding services (optional)
HUNTER_API_KEY="your_hunter_key"
APOLLO_API_KEY="your_apollo_key"
ROCKETREACH_API_KEY="your_rocketreach_key"

# LLM Configuration
LLM_PROVIDER="anthropic"  # or "cohere"
LLM_MODEL="claude-3-sonnet-20240229"  # or "command" for Cohere
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.7