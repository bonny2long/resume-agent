{
  "name": "resume-agent",
  "version": "1.0.0",
  "description": "AI-powered resume tailoring agent with hiring manager research and LinkedIn outreach",
  "main": "dist/cli/index.js",
  "bin": {
    "resume-agent": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "nodemon --exec \"ts-node -r tsconfig-paths/register\" src/cli/index.ts --",
    "dev:analyze": "npm run dev -- analyze",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node src/database/seed.ts",
    "db:reset": "prisma migrate reset",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^21.0.0",
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.3",
    "cohere-ai": "^7.20.0",
    "commander": "^12.0.0",
    "date-fns": "^3.0.0",
    "docx": "^8.5.0",
    "dotenv": "^16.4.0",
    "handlebars": "^4.7.8",
    "inquirer": "^9.2.0",
    "langchain": "^1.2.16",
    "mammoth": "^1.6.0",
    "markdown-it": "^14.0.0",
    "nanoid": "^5.0.4",
    "openai": "^4.20.1",
    "ora": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pgvector": "^0.1.8",
    "puppeteer": "latest",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.10.9",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.1.1",
    "prisma": "^5.10.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
