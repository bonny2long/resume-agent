generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MasterResume {
  id             String          @id @default(uuid())
  version        Int             @default(1)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  fullName       String
  email          String
  phone          String
  location       String
  linkedInUrl    String?
  githubUrl      String?
  portfolioUrl   String?
  summaryShort   String
  summaryLong    String
  certifications Certification[]
  education      Education[]
  experiences    Experience[]
  projects       Project[]
  skills         Skill[]

  @@map("master_resumes")
}

model Experience {
  id           String        @id @default(uuid())
  resumeId     String
  company      String
  title        String
  location     String
  startDate    DateTime
  endDate      DateTime?
  current      Boolean       @default(false)
  description  String?
  embedding    Float[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  achievements Achievement[]
  resume       MasterResume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  technologies TechStack[]   @relation("ExperienceToTechStack")

  @@unique([resumeId, company, title, startDate])
  @@map("experiences")
}

model Achievement {
  id           String     @id @default(uuid())
  experienceId String
  description  String
  metrics      String?
  keywords     String[]
  embedding    Float[]
  createdAt    DateTime   @default(now())
  impact       Impact     @default(medium)
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model Project {
  id           String       @id @default(uuid())
  resumeId     String
  name         String
  description  String
  role         String
  githubUrl    String?
  liveUrl      String?
  featured     Boolean      @default(false)
  startDate    DateTime
  endDate      DateTime
  achievements String[]
  embedding    Float[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  resume       MasterResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  technologies TechStack[]  @relation("ProjectToTechStack")

  @@unique([resumeId, name])
  @@map("projects")
}

model TechStack {
  id          String       @id @default(uuid())
  name        String       @unique
  category    TechCategory @default(tool)
  experiences Experience[] @relation("ExperienceToTechStack")
  projects    Project[]    @relation("ProjectToTechStack")
  skills      Skill[]      @relation("SkillToTechStack")

  @@map("tech_stack")
}

model Skill {
  id           String       @id @default(uuid())
  resumeId     String
  name         String
  category     String
  proficiency  Proficiency  @default(intermediate)
  resume       MasterResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  technologies TechStack[]  @relation("SkillToTechStack")

  @@unique([resumeId, name])
  @@map("skills")
}

model Education {
  id          String       @id @default(uuid())
  resumeId    String
  institution String
  degree      String
  field       String
  startDate   DateTime
  endDate     DateTime?
  gpa         String?
  resume      MasterResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("education")
}

model Certification {
  id           String       @id @default(uuid())
  resumeId     String
  name         String
  issuer       String
  issueDate    DateTime
  expiryDate   DateTime?
  credentialId String?
  url          String?
  resume       MasterResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model Company {
  id             String   @id @default(uuid())
  name           String   @unique
  domain         String?
  industry       String?
  size           String?
  founded        Int?
  headquarters   String?
  values         String[]
  workStyle      String[]
  benefits       String[]
  techStack      String[]
  recentNews     Json?
  lastResearched DateTime @updatedAt
  createdAt      DateTime @default(now())
  jobs           Job[]

  @@map("companies")
}

model Job {
  id               String          @id @default(uuid())
  companyId        String
  title            String
  url              String?
  location         String
  salary           String?
  postedDate       DateTime?
  rawDescription   String
  requiredSkills   String[]
  preferredSkills  String[]
  responsibilities String[]
  qualifications   String[]
  keywords         String[]
  skillsMatch      Int?
  experienceLevel  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  applications     Application[]
  hiringManagers   HiringManager[]
  company          Company         @relation(fields: [companyId], references: [id])

  @@unique([companyId, title])
  @@map("jobs")
}

model HiringManager {
  id          String            @id @default(uuid())
  jobId       String
  name        String
  title       String
  department  String?
  linkedInUrl String?
  email       String?
  phone       String?
  profileData Json?
  confidence  Int
  sources     String[]
  foundAt     DateTime          @default(now())
  lastUpdated DateTime          @updatedAt
  verified    Boolean           @default(false)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  messages    LinkedInMessage[]

  @@map("hiring_managers")
}

model LinkedInMessage {
  id                  String        @id @default(uuid())
  hiringManagerId     String
  type                String
  subject             String?
  body                String
  characterCount      Int
  personalizationTags String[]
  tone                String
  status              String        @default("draft")
  createdAt           DateTime      @default(now())
  sentAt              DateTime?
  responseAt          DateTime?
  hiringManager       HiringManager @relation(fields: [hiringManagerId], references: [id], onDelete: Cascade)

  @@map("linkedin_messages")
}

model Application {
  id              String    @id @default(uuid())
  jobId           String
  resumePath      String?
  coverLetterPath String?
  atsScore        Int?
  keywordMatch    Int?
  channels        String[]
  timeline        Json?
  status          String    @default("draft")
  appliedAt       DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  job             Job       @relation(fields: [jobId], references: [id])

  @@map("applications")
}

model GitHubRepo {
  id            String    @id @default(uuid())
  name          String
  fullName      String    @unique
  description   String?
  url           String
  languages     String[]
  topics        String[]
  stars         Int
  forks         Int
  lastCommit    DateTime?
  createdAt     DateTime
  updatedAt     DateTime
  isPrivate     Boolean   @default(false)
  isFork        Boolean   @default(false)
  readmeContent String?
  lastSynced    DateTime  @updatedAt

  @@map("github_repos")
}

enum Proficiency {
  beginner
  intermediate
  advanced
  expert
}

enum Impact {
  high
  medium
  low
}

enum SkillCategory {
  technical
  soft
}

enum TechCategory {
  language
  framework
  tool
  database
  cloud
  other
}
